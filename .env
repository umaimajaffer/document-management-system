# Local development defaults only. Override these with real values in Vercel.
DATABASE_URL="postgresql://user:password@localhost:5432/docupoc?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Optional. Defaults to storage/uploads locally and /tmp/docupoc-uploads on Vercel.
FILE_STORAGE_ROOT=""
