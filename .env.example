DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Optional. Leave unset on Vercel unless you intentionally use ephemeral local storage.
# For persistent production uploads, replace local filesystem storage with S3/Vercel Blob.
FILE_STORAGE_ROOT=""
